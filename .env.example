# Copy to .env.local and fill in real values. .env.local is gitignored.
#
# Required for scripts/generate-atlas-row.ts and scripts/generate-atlas-batch.ts.

# PQS customer API key. Pulls from pqs_api_keys table in the PQS Supabase
# instance. Used for both /api/score/full (pre-flight) and
# /api/atlas/score/output (post-flight). Format: PQS_<base64-ish>, or
# pqs_live_<base64-ish> for Stripe-issued subscription keys, or
# orbis_<hex> for Orbis marketplace-issued keys.
PQS_API_KEY=PQS_your_customer_bearer_key

# Internal attribution token. Sent in the X-PQS-Internal header so that
# atlas traffic is flagged is_internal=true in pqs_api_calls — that way
# atlas row generation doesn't pollute external customer-usage analytics.
# This is NOT a customer API key; validateApiKey ignores it.
PQS_INTERNAL_TOKEN=your_internal_attribution_token

# Optional override — set when testing against a different PQS host
# (e.g. preview deploys, staging). Default: https://pqs.onchainintel.net
# PQS_BASE_URL=https://your-preview.vercel.app

# ---------------------------------------------------------------------------
# Beat 2 — Virtuals Agent Commerce Protocol (ACP) v2 integration.
# ---------------------------------------------------------------------------
# Required only when running bin/atlas-agent.ts serve|buy against the
# Virtuals marketplace. Chain: Base mainnet. Payment route: x402 via
# baseAcpX402ConfigV2 (real on-chain USDC transfers recorded on Basescan).

# Seller — the pqs-atlas-agent provider wallet.
# VIRTUALS_AGENT_WALLET is the smart-wallet address registered on
# https://app.virtuals.io/acp/join. VIRTUALS_AGENT_PRIVATE_KEY is the
# whitelisted signer. VIRTUALS_SESSION_ENTITY_KEY_ID is the integer session
# entity ID from the Virtuals agent registry.
VIRTUALS_AGENT_WALLET=0xYourSellerSmartWallet
VIRTUALS_AGENT_PRIVATE_KEY=0xYourSellerWhitelistedPrivateKey
VIRTUALS_SESSION_ENTITY_KEY_ID=0

# Buyer — the wallet that initiates targeted jobs against the seller.
# Same whitelist rules apply. VIRTUALS_BUYER_ENTITY_ID is the buyer's
# session entity ID (separate from the seller's).
VIRTUALS_BUYER_WALLET=0xYourBuyerSmartWallet
VIRTUALS_BUYER_PRIVATE_KEY=0xYourBuyerWhitelistedPrivateKey
VIRTUALS_BUYER_ENTITY_ID=0
