# Atlas data — generated output is gitignored; selected final datasets get
# committed separately when ready. Source/input files under data/ are NOT
# generated output and SHOULD be tracked.
data/*.csv
data/*.json
data/*.jsonl
data/atlas-failures.jsonl

# Inputs + directory marker — must stay tracked
!data/.gitkeep
!data/source-prompts.jsonl

# Pipeline 4 deliverables — 4 final corpus files are tracked
!data/source-prompts-full-deterministic.jsonl
!data/source-prompts-full-sampled.jsonl
!data/source-prompts-clean-deterministic.jsonl
!data/source-prompts-clean-sampled.jsonl

# Pipeline 4 pilot evidence — tracked (included in PR #1)
!data/pilots/
!data/pilots/**

# Pipeline 5 deliverables — kappa-calibration artifacts are tracked
!data/pipeline-5-anchors.jsonl
!data/pipeline-5-rater-outputs.jsonl
!data/pipeline-5-kappa-results.json
